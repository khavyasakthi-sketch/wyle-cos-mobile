# API
EXPO_PUBLIC_API_URL=http://localhost:3000/api
EXPO_PUBLIC_API_TIMEOUT=10000

# App
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_APP_VERSION=1.0.0

# Anthropic (Claude AI — used by Buddy chat + Life Signal Engine)
# Get from: https://console.anthropic.com/settings/api-keys
EXPO_PUBLIC_ANTHROPIC_API_KEY=sk-ant-...

# Google OAuth (Gmail + Calendar — Life Signal Engine)
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# For Expo Go / Web testing: use the Web application Client ID
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
# For production Android APK: create an Android OAuth client, paste here
# EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=your-android-client-id.apps.googleusercontent.com
# For production iOS IPA: create an iOS OAuth client, paste here
# EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=your-ios-client-id.apps.googleusercontent.com
